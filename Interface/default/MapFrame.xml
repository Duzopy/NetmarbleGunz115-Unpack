<?xml version="1.0" encoding="euc-kr"?>
<XML ID="Stage">
	<Schema xmlns="MaietData" xmlns:dt="MaietDataTypes" />
	<FRAME item="MapFrame">
		<BOUNDS>
			<X>0</X>
			<Y>0</Y>
			<W>400</W>
			<H>300</H>
		</BOUNDS>
