			<HALIGN>left</HALIGN>
			<VALIGN>top</VALIGN>
		</ALIGN>
		<BOUNDS>
			<X>0</X>
			<Y>0</Y>
			<W>600</W>
			<H>50</H>
		</BOUNDS>
		<TEXT>No Message</TEXT>
	</LABEL>

<!-- 메뉴 -->

	<FRAME item="CombatMenuFrame">
		<FRAMELOOK>NormalFrameLook</FRAMELOOK>
		<BOUNDS>
			<X>0</X>
			<Y>0</Y>
			<W>240</W>
			<H>158</H>
		</BOUNDS>
		<ALIGN>
			<HALIGN>center</HALIGN>
			<VALIGN>center</VALIGN>
		</ALIGN>
		<RESIZABLE>false</RESIZABLE>
		<MOVABLE>true</MOVABLE>
		<VISIBLE>false</VISIBLE>
		<FOCUSABLE>false</FOCUSABLE>
		<TEXT>게임 메뉴</TEXT>
	</FRAME>

	<BUTTON item="OptionFrame" parent="CombatMenuFrame">
		<BUTTONLOOK>NormalButtonLook</BUTTONLOOK>
		<ANCHORS>
			<LEFT>true</LEFT>
			<TOP>true</TOP>
			<RIGHT>true</RIGHT>
			<BOTTOM>true</BOTTOM>
		</ANCHORS>
		<BOUNDS>
			<X>20</X>
			<Y>30</Y>
			<W>200</W>
			<H>25</H>
		</BOUNDS>
		<TEXT>옵 션(&amp;O)</TEXT>
	</BUTTON>
	<BUTTON item="CombatMenuClose" parent="CombatMenuFrame">
		<BUTTONLOOK>NormalButtonLook</BUTTONLOOK>
		<ANCHORS>
			<LEFT>true</LEFT>
			<TOP>true</TOP>
			<RIGHT>true</RIGHT>
			<BOTTOM>true</BOTTOM>
		</ANCHORS>
		<BOUNDS>
			<X>20</X>
			<Y>62</Y>
			<W>200</W>
			<H>25</H>
		</BOUNDS>
		<TEXT>게임으로 돌아가기(&amp;X)</TEXT>
		<DEFAULTKEY>ESC</DEFAULTKEY>
	</BUTTON>
	<BUTTON item="StageExit" parent="CombatMenuFrame">
		<BUTTONLOOK>NormalButtonLook</BUTTONLOOK>
		<ANCHORS>
			<LEFT>true</LEFT>
			<TOP>true</TOP>
			<RIGHT>true</RIGHT>
			<BOTTOM>true</BOTTOM>
		</ANCHORS>
		<BOUNDS>
			<X>20</X>
			<Y>94</Y>
			<W>200</W>
			<H>25</H>
		</BOUNDS>
		<TEXT>게임에서 나가기(&amp;L)</TEXT>
	</BUTTON>
	<BUTTON item="Exit" parent="CombatMenuFrame">
		<BUTTONLOOK>NormalButtonLook</BUTTONLOOK>
		<ANCHORS>
			<LEFT>true</LEFT>
			<TOP>true</TOP>
			<RIGHT>true</RIGHT>
			<BOTTOM>true</BOTTOM>
		</ANCHORS>
		<BOUNDS>
			<X>20</X>
			<Y>126</Y>
			<W>200</W>
			<H>25</H>
		</BOUNDS>
		<TEXT>프로그램 종료(&amp;Q)</TEXT>
	</BUTTON>

	<!-- 콤보 등의 메세지 -->
	
	<LABEL item="CombatEffectMsgLabel">
		<LABELLOOK>HPAPLabelLook</LABELLOOK>
		<ANCHORS>
			<LEFT>true</LEFT>
			<TOP>true</TOP>
			<RIGHT>false</RIGHT>
			<BOTTOM>false</BOTTOM>
		</ANCHORS>
